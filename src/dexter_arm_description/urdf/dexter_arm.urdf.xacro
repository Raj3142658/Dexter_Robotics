<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="dexter_arm">

    <!-- Pure robot geometry - NO ros2_control here -->
    <!-- ros2_control is added by overlay xacros (gazebo/hardware) -->

    <!-- Add dummy world link and fixed base_joint so base_link is not the URDF root -->
    <link name="world" />
    <joint name="base_joint" type="fixed">
        <parent link="world" />
        <child link="base_link" />
        <origin rpy="0 0 0" xyz="0 0 0" />
    </joint>

    <!-- Base Link -->
